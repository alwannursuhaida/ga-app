// Prisma schema — GA Yayasan App
// made by al with love

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id                    String    @id @default(cuid())
  name                  String    @unique
  label                 String    // label tampilan, e.g. "SMP Albanna"
  namaPenanggungJawab   String?   // nama Wakil Kepala Sarpra unit ini (atau nama Kadiv GA untuk unit YAYASAN)
  namaKepalaSekolah     String?   // nama Kepala Sekolah unit ini (khusus unit sekolah, kosong untuk YAYASAN)
  users                 User[]
  assets                Asset[]
  requests              Request[]
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("STAFF")
  unitId       String
  unit         Unit      @relation(fields: [unitId], references: [id])
  requests     Request[]
  createdAt    DateTime  @default(now())
}

model Asset {
  id          String          @id @default(cuid())
  kode        String          @unique      // kode inventaris, mis. AST-SMP-0001
  nama        String
  kategori    String                       // mis. "Elektronik", "Furnitur", "Olahraga"
  kondisi     String          @default("BAIK")
  lokasi      String                       // mis. "Ruang Kelas 7A", "Lab Komputer"
  unitId      String
  unit        Unit            @relation(fields: [unitId], references: [id])
  jumlah      Int             @default(1)
  keterangan  String?
  tahunPengadaan Int?
  hargaBeli   Float?
  hargaJual   Float?
  masaManfaat Int?                          // dalam tahun, dasar hitung penyusutan
  requests    Request[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Request {
  id            String        @id @default(cuid())
  type          String
  title         String
  description   String
  status        String        @default("DIAJUKAN")
  catatanGA     String?                       // catatan/alasan dari GA saat memproses/menolak
  tanggalMulai  DateTime?                     // khusus PEMINJAMAN
  tanggalSelesai DateTime?                    // khusus PEMINJAMAN
  lokasiPerbaikan String?                     // khusus PERBAIKAN
  tingkatKerusakan String?                    // khusus PERBAIKAN: RINGAN | SEDANG | BERAT
  urgensi         String?                     // khusus PERBAIKAN: SEGERA | DAPAT_MENUNGGU
  dokumenUrl      String?                     // khusus PERBAIKAN: PDF hasil TTD yang diunggah
  fotoSebelum   String?                       // khusus PERBAIKAN — diunggah staff pengaju
  fotoSesudah   String?                       // khusus PERBAIKAN — diunggah GA
  tenggatWaktu  DateTime?                     // diisi GA saat status diubah ke DIPROSES
  assetId       String?
  asset         Asset?        @relation(fields: [assetId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  unitId        String
  unit          Unit          @relation(fields: [unitId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
