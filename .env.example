# Database (Neon Postgres) — dapatkan dari dashboard Neon setelah bikin project
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require"

# Secret untuk session login — ganti dengan string acak panjang, JANGAN pakai contoh ini
SESSION_SECRET="ubah-ini-dengan-string-acak-yang-panjang-dan-rahasia"

# Netlify Blobs (foto & dokumen) — TIDAK perlu env var manual.
# Saat di-deploy ke Netlify, kredensial otomatis tersedia.
# Untuk development lokal, jalankan lewat "netlify dev" (bukan "npm run dev" biasa)
# supaya fitur upload foto/dokumen bisa dites — lihat README bagian development lokal.
